# Application
APP_NAME=redis-social-feed
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=change_me_in_production_please_use_long_random_string
ACCESS_TOKEN_TTL_SECONDS=86400

# PostgreSQL (long-term storage only)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=feeduser
POSTGRES_PASSWORD=feedpass
POSTGRES_DB=feeddb

# Redis (primary data plane)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Feed
FEED_MAX_SIZE=1000
FANOUT_BATCH_SIZE=500
CELEBRITY_FOLLOWER_THRESHOLD=10000

# Rate limiting (defaults per endpoint group)
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_WRITE_PER_MINUTE=30

# Trending
TRENDING_DECAY_LAMBDA=0.08
TRENDING_WINDOW_HOURS=48
